# ─── Database (PostgreSQL) ──────────────────────────────────────
# OPTION A — Render / Railway / any managed Postgres (recommended for deployment):
# Paste the single connection string they give you (e.g. Render's "Internal Database URL").
# When DATABASE_URL is set, it overrides the individual DB_* vars below.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# OPTION B — Local development (individual fields):
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_NAME=divine_stack_db

# Set to true when using Option B against a managed provider that requires SSL.
# (Option A / DATABASE_URL already enables SSL by default — set DB_SSL=false to disable it.)
DB_SSL=false

# ─── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT (CHANGE THIS to a long random string in production!) ─
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dst_super_secret_jwt_key_change_this_123!
JWT_EXPIRES=8h

# ─── CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── First Admin Bootstrap (optional — only needed once) ─────
# If set, and no admin exists yet, the server auto-creates this admin on
# startup. Useful when you have no Shell access (e.g. Render free tier) to
# run `npm run setup-admin` interactively. Remove these 4 lines again after
# you've confirmed you can log in.
# ADMIN_USERNAME=admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_FULL_NAME=Super Admin
# ADMIN_PASSWORD=change_this_to_a_strong_password
