# ─── Database (PostgreSQL) ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_NAME=divine_stack_db
# Set to true for managed Postgres providers (Render, Railway, Aiven, etc.)
DB_SSL=false

# ─── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT (CHANGE THIS to a long random string in production!) ─
JWT_SECRET=dst_super_secret_jwt_key_change_this_123!
JWT_EXPIRES=8h

# ─── CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
